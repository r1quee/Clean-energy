<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lista de Produtos</title>
  <link rel="stylesheet" href="/css/listaprodutos.css">
  <link rel="stylesheet" href="/css/sidebar_perfil.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partial/header.ejs') %>
  <nav class="perfil-layout">
    <% const activePage = 'produtos'; %>
    <%- include('../partial/sidebar_perfil.ejs') %>

    <!-- Conteúdo -->
    <main class="perfil-layout__content">
    <section class="content" style="padding:0;">
      
      <!-- Botão voltar -->
      <nav class="back-navigation" aria-label="Navegação de retorno">
    <button class="back-button" onclick="history.back()" aria-label="Voltar à página anterior">
      <i class='bx bx-arrow-back'></i>
      <span>Voltar</span>
    </button>
  </nav>

      <!-- Botão novo produto -->
      <a href="/cadastrar_produto" class="btn-novo-produto">
        <i class='bx bx-plus'></i>
        Novo Produto
      </a>

      <!-- Lista de produtos -->
      <section class="produtos-grid">
        <% if (produtos && produtos.length > 0) { %>
          <% produtos.forEach(produto => { %>
            <article class="produto-card" data-id="<%= produto.id %>">
              <figure>
                <img src="<%= produto.imagem && produto.imagem.startsWith('data:') ? produto.imagem : '/imagem/' + (produto.imagem || 'sem-foto.png') %>" alt="<%= produto.nome %>" onerror="this.src='https://placehold.co/300x200?text=Sem+Foto'">
              </figure>
              <section class="produto-info">
                <h3><%= produto.nome %></h3>
                <p class="endereco"><%= produto.local %></p>
                <p class="preco">R$ <%= parseFloat(produto.preco).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></p>
                <p class="quantidade"><%= produto.quantidade %></p>
              </section>
              <section class="acoes">
                <button class="btn btn-warning btn-sm">Editar</button>
                <button class="btn btn-danger btn-sm btn-excluir">Excluir</button>
              </section>
            </article>
          <% }) %>
        <% } else { %>
          <p style="grid-column: 1/-1; text-align: center; padding: 2rem;">Nenhum produto cadastrado ainda.</p>
        <% } %>
      </section>
    </section>

    </section>
    </main>
  </nav>

  <script src="/js/listaprodutos.js"></script>
  <script src="/js/produto-delete.js"></script>

  <!-- Modal de Edição -->
  <section class="modal fade" id="editarModal" tabindex="-1" aria-labelledby="editarModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
      <section class="modal-content">
        <section class="modal-header">
          <h5 class="modal-title" id="editarModalLabel">Editar Produto</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </section>
        <section class="modal-body">
          <form id="formEditarProduto" novalidate>
            <nav class="mb-3 form-group-validation">
              <label for="editarNome" class="form-label">Nome do Produto</label>
              <input type="text" class="form-control" id="editarNome" required>
              <span class="error-message" id="errorNome"></span>
            </nav>
            <nav class="mb-3 form-group-validation">
              <label for="editarEndereco" class="form-label">Endereço</label>
              <input type="text" class="form-control" id="editarEndereco" required>
              <span class="error-message" id="errorEndereco"></span>
            </nav>
            <nav class="mb-3 form-group-validation">
              <label for="editarPreco" class="form-label">Preço (R$)</label>
              <input type="text" class="form-control" id="editarPreco" required placeholder="Ex: 1500,00">
              <span class="error-message" id="errorPreco"></span>
            </nav>
            <nav class="mb-3 form-group-validation">
              <label for="editarQuantidade" class="form-label">Quantidade</label>
              <input type="text" class="form-control" id="editarQuantidade" required placeholder="Ex: 20 Tonelada(s)">
              <span class="error-message" id="errorQuantidade"></span>
            </nav>
          </form>
        </section>
        <section class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="button" class="btn btn-primary" id="salvarEdicaoBtn" disabled>Salvar Alterações</button>
        </section>
      </section>
    </section>
  </section>


<section class="modal fade" id="excluirModal" tabindex="-1" aria-labelledby="excluirModalLabel" aria-hidden="true">
  <section class="modal-dialog modal-dialog-centered">
    <section class="modal-content">
      <section class="modal-header">
        <h5 class="modal-title" id="excluirModalLabel">Confirmar Exclusão</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </section>
      <section class="modal-body">
        Tem certeza que deseja excluir este produto?
      </section>
      <section class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-danger" id="confirmarExcluirBtn">Excluir</button>
      </section>
    </section>
  </section>
</section>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script src="/js/listaprodutos.js"></script>

<%- include('../partial/footer.ejs') %>
<script src="/js/darkmode.js"></script>
</body>
</html>

