<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detalhes do Usuário - Admin</title>
  <link rel="stylesheet" href="/css/adm.css">
  <link rel="stylesheet" href="/css/detalhes_user.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <%- include('../partial/header.ejs') %>

  <section class="admin-container">
    <%- include('../partial/sidebar_adm.ejs') %>

    <main class="admin-main">
      <header class="details-header">
        <nav class="back-navigation" aria-label="Navegação de retorno">
          <button class="back-button" onclick="history.back()" aria-label="Voltar à página anterior">
            <i class='bx bx-arrow-back'></i>
            <span>Voltar</span>
          </button>
        </nav>
        <article class="header-content">
          <h1>Detalhes do Usuário</h1>
          <p class="page-subtitle">Informações completas e histórico de transações</p>
        </article>
      </header>

      <article id="userContent">
        <!-- Conteúdo carregado pelo JavaScript -->
      </article>
    </main>
  </section>

  <!-- ═══════════════════════════════════════════════
       MODAL DE AVALIAÇÕES
  ═══════════════════════════════════════════════ -->
  <dialog id="avaliacoesModal" class="avaliacoes-modal">
    <article class="avaliacoes-content">
      <button class="close-modal" onclick="closeModal()">&times;</button>
      <h2><i class='bx bxs-star'></i> Avaliações Detalhadas</h2>
      <p class="subtitle">Avaliações de <span id="modalUserName">-</span></p>
      <section class="avaliacoes-grid">
        <article class="avaliacoes-col">
          <h3>Avaliações Dadas</h3>
          <section id="modalGivenReviews"></section>
        </article>
      </section>
    </article>
  </dialog>

  <!-- ═══════════════════════════════════════════════
       MODAL PERSONALIZADO (suspender / excluir conta)
  ═══════════════════════════════════════════════ -->
  <nav id="customModal" class="custom-modal">
    <nav class="modal-content">
      <h3 id="modalTitle">Confirmação</h3>
      <p id="modalMessage"></p>
      <nav class="modal-actions">
        <button class="btn-cancel" onclick="closeCustomModal()">Cancelar</button>
        <button class="btn-confirm" id="confirmBtn">Confirmar</button>
      </nav>
    </nav>
  </nav>

  <!-- ═══════════════════════════════════════════════
       MODAL DE CONFIRMAÇÃO DE AVALIAÇÃO
  ═══════════════════════════════════════════════ -->
  <nav class="confirm-modal-overlay" id="confirmAvalModal" onclick="if(event.target===this) closeConfirmModal()">
    <nav class="confirm-modal">
      <nav class="confirm-modal-icon" id="confirmAvalIcon">⚠️</nav>
      <h3 id="confirmAvalTitle">Suspender comentário?</h3>
      <p id="confirmAvalMsg">Este comentário ficará oculto para todos os usuários.</p>
      <nav class="confirm-modal-actions">
        <button class="confirm-btn-cancel" onclick="closeConfirmModal()">Cancelar</button>
        <button class="confirm-btn-confirm" id="confirmAvalBtn">Sim, suspender</button>
      </nav>
    </nav>
  </nav>

  <!-- ═══════════════════════════════════════════════
       DADOS DO SERVIDOR (EJS → JS)
  ═══════════════════════════════════════════════ -->
  <script id="server-user-data" type="application/json">
    <%- JSON.stringify(typeof usuario !== 'undefined' ? usuario : null) %>
  </script>
  <script id="server-avaliacoes" type="application/json">
    <%- JSON.stringify(typeof avaliacoesDadas !== 'undefined' ? avaliacoesDadas : []) %>
  </script>

  <!-- ═══════════════════════════════════════════════
       JAVASCRIPT PRINCIPAL
  ═══════════════════════════════════════════════ -->
  <script>
    /* ── Hidratação dos dados do servidor ── */
    window.__SERVER_USER__ = JSON.parse(
      document.getElementById('server-user-data').textContent
    );

    const _rawAvals = JSON.parse(
      document.getElementById('server-avaliacoes').textContent || '[]'
    );

    if (_rawAvals.length > 0 && window.__SERVER_USER__) {
      window.__SERVER_USER__.given = _rawAvals.map(function(a) {
        return {
          id:       a.Avaliacao_ID,
          product:  a.produto_nome || 'Produto',
          score:    a.Nota || 0,
          comment:  a.Comentario || '',
          date:     a.criado_em
                      ? new Date(a.criado_em).toLocaleDateString('pt-BR')
                      : '-',
          suspensa: a.suspensa || 0
        };
      });
    }

    /* ── Utilitários ── */
    function getUserIdFromUrl() {
      return new URLSearchParams(window.location.search).get('userId');
    }

    function renderStars(score) {
      var full  = Math.floor(score);
      var half  = score % 1 !== 0;
      var html  = '';
      for (var i = 0; i < full; i++)        html += '<i class="fas fa-star"></i>';
      if (half)                              html += '<i class="fas fa-star-half-alt"></i>';
      for (var j = 0; j < 5 - Math.ceil(score); j++) html += '<i class="far fa-star"></i>';
      return html;
    }

    function fmtCPF(v) {
      if (!v) return null;
      var d = String(v).replace(/\D/g, '');
      return d.length !== 11 ? v : d.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4');
    }

    function fmtCNPJ(v) {
      if (!v) return null;
      var d = String(v).replace(/\D/g, '');
      return d.length !== 14 ? v : d.replace(/(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})/, '$1.$2.$3/$4-$5');
    }

    /* ── Renderização principal ── */
    function displayUserContent(userId) {
      var contentDiv = document.getElementById('userContent');

      if (!window.__SERVER_USER__) {
        contentDiv.innerHTML = '<article class="empty-state"><p>Usuário não encontrado.</p></article>';
        return;
      }

      var s       = window.__SERVER_USER__;
      var isPJ    = s.Tipo === 'PJ';
      var docLabel = isPJ ? 'CNPJ' : 'CPF';
      var docValue = isPJ ? fmtCNPJ(s.CNPJ) : fmtCPF(s.CPF);

      var user = {
        name:            s.Nome        || s.name        || '',
        email:           s.Email       || s.email       || '',
        cpf:             docValue,
        docLabel:        docLabel,
        tipo:            isPJ ? 'Vendedor (PJ)' : 'Comprador (PF)',
        biografia:       s.Biografia   || null,
        ultimoLogin:     s.Ultimo_Login
                           ? new Date(s.Ultimo_Login).toLocaleString('pt-BR')
                           : null,
        dataCriacao:     s.Data_Criacao
                           ? new Date(s.Data_Criacao).toLocaleDateString('pt-BR')
                           : null,
        address:         s.Endereco    || s.address     || '',
        salesCount:      s.salesCount  || 0,
        salesTotal:      s.salesTotal  || 'R$ 0,00',
        purchasesCount:  s.purchasesCount || 0,
        purchasesTotal:  s.purchasesTotal || 'R$ 0,00',
        rating:          s.rating      || null,
        status:          s.status      || 'active',
        given:           s.given       || [],
        received:        s.received    || [],
        products:        s.products    || [],
        purchasedProducts: s.purchasedProducts || []
      };

      var isSuspended  = user.status === 'suspended';
      var statusStyle  = isSuspended
        ? 'background:#fee2e2;color:#991b1b;'
        : 'background:#d1fae5;color:#065f46;';
      var statusLabel  = isSuspended ? 'SUSPENSO' : 'ATIVO';

      var suspendBtn = isSuspended
        ? '<button class="action-btn-small" onclick="suspendAccount(\'' + userId + '\')" style="background:#d1fae5;color:#065f46;border:1px solid #6ee7b7;padding:8px 14px;border-radius:8px;cursor:pointer;display:inline-flex;align-items:center;gap:6px;font-weight:600;"><i class=\'bx bx-check-circle\'></i>Reativar Conta</button>'
        : '<button class="action-btn-small btn-suspend" onclick="suspendAccount(\'' + userId + '\')"><i class=\'bx bx-block\'></i>Suspender Conta</button>';

      var html = '<section class="user-profile-card">' +
        '<header class="profile-header">' +
          '<article class="profile-info">' +
            '<figure class="profile-avatar"><i class=\'bx bx-user\'></i></figure>' +
            '<article>' +
              '<h2>' + user.name + '</h2>' +
              '<p>' + (user.email || 'Não informado') + '</p>' +
              '<span class="status-badge" style="' + statusStyle + '">' + statusLabel + '</span>' +
              '<nav class="profile-actions">' +
                suspendBtn +
                '<button class="action-btn-small btn-delete" onclick="deleteAccount(\'' + userId + '\')" style="background:#fee2e2;color:#dc2626;border:1px solid #fca5a5;padding:8px 14px;border-radius:8px;cursor:pointer;display:inline-flex;align-items:center;gap:6px;font-weight:600;margin-left:8px;">' +
                  '<i class=\'bx bx-trash\'></i>Excluir Conta' +
                '</button>' +
              '</nav>' +
            '</article>' +
          '</article>' +
          '<article class="profile-rating">' +
            '<span class="rating-label">Avaliação Média</span>' +
            '<article class="rating-display">' +
              '<span class="rating-value">' + (user.rating ? user.rating.toFixed(1) : 'N/A') + '</span>' +
              '<i class=\'bx bxs-star\'></i>' +
            '</article>' +
          '</article>' +
        '</header>' +

        '<section class="info-section">' +
          '<header class="section-header"><h3>Informações do Usuário</h3></header>' +
          '<header class="section-header" style="margin-top:20px;margin-bottom:15px;">' +
            '<h4 style="font-size:1.1rem;color:#6b7280;font-weight:600;margin:0;">Informações Pessoais</h4>' +
          '</header>' +
          '<section class="info-grid">' +
            '<article class="info-item"><i class="info-icon bx bx-envelope"></i><article><label>Email</label><p>' + (user.email || 'Não informado') + '</p></article></article>' +
            '<article class="info-item"><i class="info-icon bx bx-id-card"></i><article><label>' + user.docLabel + '</label><p>' + (user.cpf || 'Não informado') + '</p></article></article>' +
            '<article class="info-item"><i class="info-icon bx bx-user-badge"></i><article><label>Tipo de conta</label><p>' + (user.tipo || 'Não informado') + '</p></article></article>' +
            (user.biografia ? '<article class="info-item"><i class="info-icon bx bx-text"></i><article><label>Biografia</label><p>' + user.biografia + '</p></article></article>' : '') +
            (user.dataCriacao ? '<article class="info-item"><i class="info-icon bx bx-calendar"></i><article><label>Membro desde</label><p>' + user.dataCriacao + '</p></article></article>' : '') +
            (user.ultimoLogin ? '<article class="info-item"><i class="info-icon bx bx-log-in-circle"></i><article><label>Último login</label><p>' + user.ultimoLogin + '</p></article></article>' : '') +
          '</section>' +
        '</section>' +

        '<section class="statistics-section">' +
          '<article class="stat-card"><i class="stat-icon bx bx-shopping-bag"></i><article><h4>Vendas Realizadas</h4><p class="stat-value">' + user.salesCount + '</p></article></article>' +
          '<article class="stat-card"><i class="stat-icon bx bx-trending-up"></i><article><h4>Total em Vendas</h4><p class="stat-value">' + user.salesTotal + '</p></article></article>' +
          '<article class="stat-card"><i class="stat-icon bx bx-cart"></i><article><h4>Compras Realizadas</h4><p class="stat-value">' + user.purchasesCount + '</p></article></article>' +
          '<article class="stat-card"><i class="stat-icon bx bx-package"></i><article><h4>Total em Compras</h4><p class="stat-value">' + user.purchasesTotal + '</p></article></article>' +
        '</section>' +
      '</section>';

      /* ── Produtos Vendidos ── */
      if (user.products && user.products.length > 0) {
        html += '<section class="user-profile-card"><section class="products-section">' +
          '<header class="section-header"><h3><i class=\'bx bx-package\'></i> Produtos Vendidos</h3></header>' +
          '<section class="products-container">';
        user.products.forEach(function(p) {
          html += '<article class="product-card">' +
            '<figure class="product-image"><img src="' + p.image + '" alt="' + p.name + '"></figure>' +
            '<article class="product-info">' +
              '<h3 class="product-name">' + p.name + '</h3>' +
              '<p class="product-price">' + p.price + '</p>' +
              '<p class="product-quantity">Quantidade: ' + p.quantity + ' unidades</p>' +
              '<time class="product-date">Vendido em: ' + p.date + '</time>' +
            '</article></article>';
        });
        html += '</section></section></section>';
      }

      /* ── Produtos Comprados ── */
      if (user.purchasedProducts && user.purchasedProducts.length > 0) {
        html += '<section class="user-profile-card"><section class="products-section">' +
          '<header class="section-header"><h3><i class=\'bx bx-cart\'></i> Produtos Comprados</h3></header>' +
          '<section class="products-container">';
        user.purchasedProducts.forEach(function(p) {
          html += '<article class="product-card">' +
            '<figure class="product-image"><img src="' + p.image + '" alt="' + p.name + '"></figure>' +
            '<article class="product-info">' +
              '<h3 class="product-name">' + p.name + '</h3>' +
              '<p class="product-price">' + p.price + '</p>' +
              '<p class="product-quantity">Quantidade: ' + p.quantity + ' unidades</p>' +
              '<time class="product-date">Comprado em: ' + p.date + '</time>' +
            '</article></article>';
        });
        html += '</section></section></section>';
      }

      /* ── Avaliações Dadas ── */
      html += '<section class="user-profile-card"><section class="info-section">' +
        '<header class="section-header"><h3><i class=\'bx bxs-star\'></i> Avaliações Dadas</h3></header>';

      if (user.given && user.given.length > 0) {
        html += '<section class="reviews-container">';
        user.given.forEach(function(review) {
          var isSuspensa = review.suspensa == 1;
          html += '<article class="review-card' + (isSuspensa ? ' review-suspensa' : '') + '" id="rc-' + review.id + '">' +
            '<header class="review-header">' +
              '<nav class="review-header-left">' +
                '<span class="review-person"><i class=\'bx bx-store-alt\'></i> ' + review.product + '</span>' +
                (isSuspensa ? '<span class="badge-suspensa"><i class=\'bx bx-block\'></i> Suspenso</span>' : '') +
              '</nav>' +
              '<time class="review-date">' + review.date + '</time>' +
            '</header>' +
            '<nav class="review-rating">' + renderStars(review.score) + '</nav>' +
            (review.comment
              ? '<blockquote class="review-comment">"' + review.comment + '"</blockquote>'
              : '<p class="review-no-comment">Sem comentário.</p>'
            ) +
            '<footer class="review-footer">' +
              (isSuspensa
                ? '<button class="btn-reativar-comment" onclick="openConfirmModal(' + review.id + ',\'reativar\',this)"><i class=\'bx bx-refresh\'></i> Reverter suspensão</button>'
                : '<button class="btn-suspender-comment" onclick="openConfirmModal(' + review.id + ',\'suspender\',this)"><i class=\'bx bx-block\'></i> Suspender comentário</button>'
              ) +
            '</footer>' +
          '</article>';
        });
        html += '</section>';
      } else {
        html += '<article class="empty-state"><p>Este usuário ainda não fez nenhuma avaliação.</p></article>';
      }

      html += '</section></section>';
      contentDiv.innerHTML = html;
    }

    /* ── Modal de avaliações (legado) ── */
    function closeModal() {
      document.getElementById('avaliacoesModal').classList.remove('show');
      document.body.classList.remove('modal-open');
    }

    /* ── Modal customizado (conta) ── */
    function openCustomModal(title, message, onConfirm) {
      var modal = document.getElementById('customModal');
      document.getElementById('modalTitle').textContent   = title;
      document.getElementById('modalMessage').textContent = message;
      var confirmBtn = document.getElementById('confirmBtn');
      confirmBtn.onclick = function() { onConfirm(); closeCustomModal(); };
      modal.classList.add('show');
    }

    function closeCustomModal() {
      document.getElementById('customModal').classList.remove('show');
    }

    /* ── Suspender / Reativar conta ── */
    async function suspendAccount(userId) {
      var s = window.__SERVER_USER__;
      if (!s || !s.id) { alert('Usuário não identificado.'); return; }

      var nome        = s.Nome || s.name || 'este usuário';
      var isSuspended = s.status === 'suspended';
      var endpoint    = isSuspended ? '/adm/usuarios/reativar' : '/adm/usuarios/suspender';
      var msg         = isSuspended
        ? 'Deseja reativar a conta de ' + nome + '?'
        : 'Tem certeza que deseja suspender a conta de ' + nome + '?';

      openCustomModal('Confirmação', msg, async function() {
        try {
          var res  = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: s.id })
          });
          var data = await res.json();
          if (res.ok && data.success) {
            showToastDU(
              isSuspended ? nome + ' foi reativado.' : nome + ' foi suspenso.',
              'success'
            );
            setTimeout(function() { location.reload(); }, 1200);
          } else {
            showToastDU('Erro: ' + (data.error || 'tente novamente.'), 'error');
          }
        } catch(e) {
          showToastDU('Erro de conexão.', 'error');
        }
      });
    }

    /* ── Excluir conta ── */
    async function deleteAccount(userId) {
      var s = window.__SERVER_USER__;
      if (!s || !s.id) { alert('Usuário não identificado.'); return; }

      var nome = s.Nome || s.name || 'este usuário';

      openCustomModal(
        'Excluir Conta',
        '⚠️ Deseja excluir permanentemente a conta de ' + nome + '?',
        async function() {
          try {
            var res  = await fetch('/adm/usuarios/excluir', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: s.id })
            });
            var data = await res.json();
            if (res.ok && data.success) {
              showToastDU('Conta de ' + nome + ' excluída.', 'success');
              setTimeout(function() {
                window.location.href = '/adm/usuarios_cadastrados';
              }, 1500);
            } else {
              showToastDU('Erro: ' + (data.error || 'tente novamente.'), 'error');
            }
          } catch(e) {
            showToastDU('Erro de conexão.', 'error');
          }
        }
      );
    }

    /* ── Toast ── */
    function showToastDU(msg, type) {
      var t = document.getElementById('duToast');
      if (!t) {
        t = document.createElement('nav');
        t.id = 'duToast';
        t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#111827;color:#fff;padding:12px 20px;border-radius:10px;font-size:.9rem;font-weight:500;z-index:9999;display:flex;align-items:center;gap:8px;opacity:0;transform:translateY(10px);transition:all .3s;';
        document.body.appendChild(t);
      }
      var icon = type === 'error'
        ? '<i class="bx bx-x-circle" style="color:#ef4444;font-size:1.2rem;"></i>'
        : '<i class="bx bx-check-circle" style="color:#10b981;font-size:1.2rem;"></i>';
      t.innerHTML = icon + '<span>' + msg + '</span>';
      t.style.opacity   = '1';
      t.style.transform = 'translateY(0)';
      setTimeout(function() {
        t.style.opacity   = '0';
        t.style.transform = 'translateY(10px)';
      }, 3000);
    }

    /* ── Modal de confirmação de avaliação ── */
    var _confirmCb = null;

    function openConfirmModal(id, action, btn) {
      _confirmCb = { id: id, action: action, btn: btn };
      var isReativar = action === 'reativar';
      document.getElementById('confirmAvalIcon').textContent  = isReativar ? '✅' : '⚠️';
      document.getElementById('confirmAvalTitle').textContent = isReativar ? 'Reverter suspensão?' : 'Suspender comentário?';
      document.getElementById('confirmAvalMsg').textContent   = isReativar
        ? 'O comentário voltará a ser exibido publicamente para todos os usuários.'
        : 'Este comentário ficará oculto para todos os usuários. Você pode reverter a qualquer momento.';
      var btn2 = document.getElementById('confirmAvalBtn');
      btn2.textContent = isReativar ? 'Sim, reverter' : 'Sim, suspender';
      btn2.className   = 'confirm-btn-confirm' + (isReativar ? ' green' : '');
      document.getElementById('confirmAvalModal').classList.add('show');
    }

    function closeConfirmModal() {
      document.getElementById('confirmAvalModal').classList.remove('show');
      _confirmCb = null;
    }

    /* ── Init ── */
    document.addEventListener('DOMContentLoaded', function() {
      /* Renderiza o conteúdo do usuário */
      var userId = getUserIdFromUrl();
      if (userId) {
        displayUserContent(userId);
      } else {
        document.getElementById('userContent').innerHTML =
          '<article class="empty-state"><p>Nenhum ID de usuário fornecido na URL.</p></article>';
      }

      /* Listener do botão de confirmar avaliação */
      document.getElementById('confirmAvalBtn').addEventListener('click', async function() {
        if (!_confirmCb) return;
        var id         = _confirmCb.id;
        var action     = _confirmCb.action;
        var btn        = _confirmCb.btn;
        closeConfirmModal();

        var suspendendo = action === 'suspender';
        var endpoint    = suspendendo ? '/adm/avaliacoes/suspender' : '/adm/avaliacoes/reativar';

        try {
          var res  = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: id })
          });
          var data = await res.json();

          if (res.ok && data.success) {
            var card   = document.getElementById('rc-' + id);
            var footer = btn ? btn.closest('.review-footer') : null;

            if (suspendendo) {
              if (card)   card.classList.add('review-suspensa');
              if (footer) footer.innerHTML = '<button class="btn-reativar-comment" onclick="openConfirmModal(' + id + ',\'reativar\',this)"><i class=\'bx bx-refresh\'></i> Reverter suspensão</button>';
              var hl = card && card.querySelector('.review-header-left');
              if (hl && !hl.querySelector('.badge-suspensa')) {
                hl.insertAdjacentHTML('beforeend', '<span class="badge-suspensa"><i class=\'bx bx-block\'></i> Suspenso</span>');
              }
              showToastDU('Comentário suspenso com sucesso.', 'success');
            } else {
              if (card)   card.classList.remove('review-suspensa');
              if (footer) footer.innerHTML = '<button class="btn-suspender-comment" onclick="openConfirmModal(' + id + ',\'suspender\',this)"><i class=\'bx bx-block\'></i> Suspender comentário</button>';
              var badge = card && card.querySelector('.badge-suspensa');
              if (badge) badge.remove();
              showToastDU('Suspensão revertida com sucesso.', 'success');
            }
          } else {
            showToastDU('Erro: ' + (data.error || 'tente novamente.'), 'error');
          }
        } catch(e) {
          showToastDU('Erro de conexão.', 'error');
        }
      });
    });
  </script>
</body>
</html>
