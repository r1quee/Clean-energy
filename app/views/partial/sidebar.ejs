<link rel="stylesheet" href="/css/sidebar.css">

<aside class="sidebar" role="complementary" aria-label="Barra lateral do usuário">
  <nav class="user-info">
    <img src="/imagem/avatar.png" alt="Foto do usuário" class="avatar">
    <p class="username"><%= typeof usuario !== 'undefined' && usuario ? usuario.Nome || usuario.nome || 'Usuário' : 'Usuário' %></p>
    <% if (typeof usuario !== 'undefined' && usuario) { %>
      <span style="font-size:0.75rem;padding:2px 10px;border-radius:20px;font-weight:600;<%= (usuario.Tipo||usuario.tipo) === 'PJ' ? 'background:#fff3e0;color:#e65100;' : 'background:#e8f5e9;color:#2e7d32;' %>">
        <%= (usuario.Tipo||usuario.tipo) === 'PJ' ? '🏪 Vendedor' : '🛒 Comprador' %>
      </span>
    <% } %>
  </nav>

  <nav class="sidebar-nav" aria-label="Navegação do usuário">
    <ul>
      <li>
        <a href="/perfil">
          <span class="two-line">
            <span class="l1">Minha</span>
            <span class="l2">Conta</span>
          </span>
        </a>
      </li>

      <% if (typeof usuario !== 'undefined' && usuario && (usuario.Tipo === 'PJ' || usuario.tipo === 'PJ')) { %>
      <li>
        <a href="/listaprodutos">
          <span class="two-line">
            <span class="l1">Meus</span>
            <span class="l2">Produtos</span>
          </span>
        </a>
      </li>
      <% } %>

      <li>
        <a href="/minhascompras">
          <span class="two-line">
            <span class="l1">Minhas</span>
            <span class="l2">Compras</span>
          </span>
        </a>
      </li>

      <li>
        <a href="/adm">
          <span class="two-line">
            <span class="l1">Adm</span>
          </span>
        </a>
      </li>
    </ul>
  </nav>
</aside>
